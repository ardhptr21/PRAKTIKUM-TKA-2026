services:
  backend:
    build: .
    ports:
      - "{{ backend_port }}:3000"
    restart: unless-stopped
    env_file:
      - .env

  db:
    image: postgres:latest
    environment:
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
      POSTGRES_DB: {{ db_name }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ db_user }} -d {{ db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    